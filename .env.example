# WISEVEO Open-Source - Environment Template
# Copy this file to .env and configure the values below.

# --- REQUIRED CONFIGURATION ---

# PostgreSQL Database URL
# Can be local (e.g. postgresql://postgres:postgres@localhost:5432/wiseveo) or hosted (Neon, Supabase, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wiseveo?schema=public"

# Auth Secret (Long random string for signing JWT session cookies)
AUTH_SECRET="replace-with-a-long-random-secret"

# Public App URL (Default is http://localhost:3000 for local development)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# --- OPTIONAL CONFIGURATION ---

# Google OAuth & Calendar Integration
# (Leave empty if you do not want to connect Google Calendar or log in via Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Telegram Bot Integration
# (Leave empty if you do not want to use the Telegram AI Bot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_CARD_FONT_PATH=""

# OpenAI API Key (Required for the Telegram AI bot module, otherwise optional)
OPENAI_API_KEY=""

# Seed passwords (required only when running db:seed / db:seed:demo).
# No default — the seed scripts abort if these are unset, so no working
# credential is ever baked into the repository.
SEED_ADMIN_PASSWORD=""
SEED_DEMO_PASSWORD=""


# --- DEV-ONLY (NEVER enable in production) ---
# Passwordless login helper for local development: visiting /api/dev/session
# signs a session cookie for DEV_SESSION_EMAIL (an account that must already
# exist) so you don't have to log in on every preview. The route hard-refuses
# (404) whenever NODE_ENV is "production", so it is dead on any real deploy
# even if these vars leak into that environment. Leave both empty/unset in
# any shared or hosted config.
DEV_AUTOLOGIN=""
DEV_SESSION_EMAIL=""
