# WISEVEO Open-Source - Environment Template
# Copy this file to .env and configure the values below.

# --- REQUIRED CONFIGURATION ---

# PostgreSQL Database URL
# Can be local (e.g. postgresql://postgres:postgres@localhost:5432/wiseveo) or hosted (Neon, Supabase, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wiseveo?schema=public"

# Auth Secret (Long random string for signing JWT session cookies)
AUTH_SECRET="replace-with-a-long-random-secret"

# Public App URL (Default is http://localhost:3000 for local development)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# --- OPTIONAL CONFIGURATION ---

# Google OAuth & Calendar Integration
# (Leave empty if you do not want to connect Google Calendar or log in via Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Telegram Bot Integration
# (Leave empty if you do not want to use the Telegram AI Bot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_CARD_FONT_PATH=""

# OpenAI API Key (Required for the Telegram AI bot module, otherwise optional)
OPENAI_API_KEY=""
